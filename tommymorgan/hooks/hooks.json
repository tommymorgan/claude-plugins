{
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/pre_push_squash.py",
						"timeout": 30000
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/post-push-cleanup.py",
						"timeout": 5000
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/stop_if_incomplete.py",
						"timeout": 5000
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/resize_images.py",
						"timeout": 5000
					}
				]
			}
		]
	}
}
